{
  "name": "msp-status-hud",
  "version": "0.2.0",
  "private": true,
  "description": "GitHub Pages MSP status HUD updated by GitHub Actions.",
  "type": "module",
  "scripts": {
    "dev": "npm run sync-assets && vite --host 0.0.0.0",
    "sync-assets": "rm -rf public/assets && cp -R assets public/assets",
    "build": "npm run sync-assets && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "update-status": "node scripts/fetch-status.js",
    "test:render": "playwright test",
    "test": "npm run build && npm run test:render"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
