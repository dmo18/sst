{
  "name": "msp-status-hud",
  "version": "2.1.5",
  "private": true,
  "description": "GitHub Pages MSP status aggregator with catalog-backed diagnostics.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/build.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "update-status": "node scripts/update-status.mjs",
    "validate-providers": "node scripts/validate-providers.mjs",
    "test": "node --test --experimental-strip-types src/__tests__/*.test.ts scripts/__tests__/*.test.js",
    "test:watch": "node --test --watch --experimental-strip-types src/__tests__/*.test.ts scripts/__tests__/*.test.js",
    "typecheck": "tsc --noEmit",
    "build:app": "vite build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
